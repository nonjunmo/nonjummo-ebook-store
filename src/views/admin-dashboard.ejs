<%- include("partials/header") %>

<section class="admin-head">
  <h1>관리자 페이지</h1>
  <div class="admin-actions">
    <a class="button primary link-button" href="/admin/products/new">상품 등록</a>
    <a class="button secondary link-button" href="/admin/orders/completed">발송완료된 주문자</a>
    <form method="post" action="/admin/logout">
      <button class="button secondary" type="submit">로그아웃</button>
    </form>
  </div>
</section>

<section class="panel">
  <h2>주문 관리</h2>
  <p class="section-note">발송완료에 체크되지 않은 주문만 표시됩니다.</p>
  <% if (orders.length === 0) { %>
    <p class="empty">접수된 주문이 없습니다.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>주문자</th>
            <th>주문 e-book</th>
            <th>금액</th>
            <th>증빙</th>
            <th>연락처 / e-mail</th>
            <th>입금확인</th>
            <th>발송완료</th>
            <th>관리</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach((order) => { %>
            <tr>
              <td><%= order.customer_name %></td>
              <td>
                <% order.items.forEach((item) => { %>
                  <div><%= item.product_title %></div>
                <% }) %>
              </td>
              <td><%= order.total_amount.toLocaleString("ko-KR") %>원</td>
              <td><%= receiptLabel(order.receipt_type) %></td>
              <td><%= order.phone %><br><%= order.email %></td>
              <td>
                <form method="post" action="/admin/orders/<%= order.id %>/payment">
                  <label class="check">
                    <input type="checkbox" name="confirmed" onchange="this.form.submit()" <%= order.payment_confirmed ? "checked" : "" %>>
                    확인
                  </label>
                </form>
              </td>
              <td>
                <form method="post" action="/admin/orders/<%= order.id %>/delivery">
                  <label class="check">
                    <input type="checkbox" name="delivered" onchange="this.form.submit()" <%= order.delivery_completed ? "checked" : "" %>>
                    발송완료
                  </label>
                </form>
              </td>
              <td>
                <form method="post" action="/admin/orders/<%= order.id %>/delete" onsubmit="return confirm('이 주문을 삭제할까요?');">
                  <button class="text-button danger" type="submit">삭제</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="panel">
  <h2>상품 목록</h2>
  <% if (products.length === 0) { %>
    <p class="empty">등록된 상품이 없습니다.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>상품명</th>
            <th>저자/소속</th>
            <th>가격</th>
            <th>상태</th>
            <th>관리</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <td><%= product.title %></td>
              <td><%= product.author %></td>
              <td><%= product.price.toLocaleString("ko-KR") %>원</td>
              <td><%= product.is_active ? "판매중" : "숨김" %></td>
              <td class="row-actions">
                <a class="text-link" href="/admin/products/<%= product.id %>/edit">수정</a>
                <form method="post" action="/admin/products/<%= product.id %>/delete" onsubmit="return confirm('이 상품을 삭제할까요? 기존 주문 내역은 유지됩니다.');">
                  <button class="text-button danger" type="submit">삭제</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
