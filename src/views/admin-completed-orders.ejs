<%- include("partials/header") %>

<section class="admin-head">
  <h1>발송완료된 주문자</h1>
  <div class="admin-actions">
    <a class="button secondary link-button" href="/admin">관리자 페이지</a>
    <a class="button primary link-button" href="/admin/orders/completed/export.csv">엑셀로 내보내기</a>
    <a class="button secondary link-button" href="/admin/orders/completed/export.html">HTML 파일</a>
  </div>
</section>

<section class="panel">
  <h2>발송완료 목록</h2>
  <p class="section-note">10명 단위로 표시됩니다. 내보내기는 발송완료된 전체 주문자를 포함합니다.</p>
  <% if (orders.items.length === 0) { %>
    <p class="empty">발송완료된 주문자가 없습니다.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>주문자</th>
            <th>주문 e-book</th>
            <th>금액</th>
            <th>증빙</th>
            <th>연락처 / e-mail</th>
            <th>입금확인</th>
            <th>주문일</th>
            <th>관리</th>
          </tr>
        </thead>
        <tbody>
          <% orders.items.forEach((order) => { %>
            <tr>
              <td><%= order.customer_name %></td>
              <td>
                <% order.items.forEach((item) => { %>
                  <div><%= item.product_title %></div>
                <% }) %>
              </td>
              <td><%= order.total_amount.toLocaleString("ko-KR") %>원</td>
              <td><%= receiptLabel(order.receipt_type) %></td>
              <td><%= order.phone %><br><%= order.email %></td>
              <td><%= order.payment_confirmed ? "확인" : "미확인" %></td>
              <td><%= order.created_at %></td>
              <td>
                <form method="post" action="/admin/orders/<%= order.id %>/delete" onsubmit="return confirm('이 주문을 삭제할까요?');">
                  <button class="text-button danger" type="submit">삭제</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (maxPage > 1) { %>
      <nav class="pagination" aria-label="발송완료 주문 페이지">
        <% for (let i = 1; i <= maxPage; i += 1) { %>
          <a class="<%= i === page ? "active" : "" %>" href="/admin/orders/completed?page=<%= i %>"><%= i %></a>
        <% } %>
      </nav>
    <% } %>
  <% } %>
</section>

<%- include("partials/footer") %>
