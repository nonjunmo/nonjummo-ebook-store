<%- include("partials/header") %>

<section class="intro">
  <h1>논준모연구소 e-book 교재</h1>
  <p>Youtube 멤버십 영상과 함께 공부할 수 있는 e-book 교재로 연구역량과 AI 활용역량을 키워보세요.</p>
  <p class="notice">계좌이체 입금 후 관리자의 입금확인을 통해 이메일로 e-book을 발송해 드립니다.</p>
</section>

<% function bulkControls(position) { %>
  <div class="bulk-controls bulk-controls-<%= position %>">
    <label class="check bulk-check">
      <input type="checkbox" data-select-all-products>
      전체 선택
    </label>
    <div class="bulk-actions">
      <button class="button secondary" type="submit" form="bulk-products-form" formaction="/cart/add-selected">선택 상품 장바구니</button>
      <button class="button primary" type="submit" form="bulk-products-form" formaction="/order/selected">선택 상품 주문하기</button>
    </div>
  </div>
<% } %>

<section class="product-list" aria-label="e-book 목록">
  <% if (products.items.length === 0) { %>
    <div class="empty">등록된 e-book이 없습니다.</div>
  <% } %>

  <% if (products.items.length > 0) { %>
    <form id="bulk-products-form" method="post"></form>
    <%- bulkControls("top") %>
  <% } %>

  <% products.items.forEach((product) => { %>
    <article class="product">
      <label class="product-select" aria-label="<%= product.title %> 선택">
        <input type="checkbox" form="bulk-products-form" name="productIds" value="<%= product.id %>" data-product-checkbox>
      </label>
      <div class="cover">
        <% if (product.cover_image_url) { %>
          <img src="<%= product.cover_image_url %>" alt="<%= product.title %> 표지">
        <% } else { %>
          <div class="cover-fallback">e-book</div>
        <% } %>
      </div>
      <div class="product-body">
        <h2><%= product.title %></h2>
        <p><%= product.author %></p>
        <% if (product.has_youtube_membership) { %>
          <p class="youtube">YouTube 멤버십 영상 있음</p>
        <% } %>
        <details>
          <summary>간략소개 / 목차보기</summary>
          <p><%= product.summary %></p>
          <pre><%= product.table_of_contents %></pre>
        </details>
        <strong class="price"><%= product.price.toLocaleString("ko-KR") %>원</strong>
      </div>
      <div class="product-actions">
        <form method="post" action="/cart/add">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <button class="button secondary" type="submit">장바구니</button>
        </form>
        <form method="post" action="/order/direct">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <button class="button primary" type="submit">주문하기</button>
        </form>
      </div>
    </article>
  <% }) %>

  <% if (products.items.length > 0) { %>
    <%- bulkControls("bottom") %>
  <% } %>
</section>

<% const maxPage = Math.ceil(products.total / products.pageSize); %>
<% if (maxPage > 1) { %>
  <nav class="pagination" aria-label="페이지">
    <% for (let i = 1; i <= maxPage; i += 1) { %>
      <a class="<%= i === page ? "active" : "" %>" href="/?page=<%= i %>"><%= i %></a>
    <% } %>
  </nav>
<% } %>

<script>
  document.querySelectorAll("[data-select-all-products]").forEach((selectAll) => {
    selectAll.addEventListener("change", () => {
      document.querySelectorAll("[data-product-checkbox]").forEach((checkbox) => {
        checkbox.checked = selectAll.checked;
      });
      document.querySelectorAll("[data-select-all-products]").forEach((other) => {
        other.checked = selectAll.checked;
      });
    });
  });
</script>

<%- include("partials/footer") %>
